{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "playwright.config.*",
    "mock.config.ts",
    "mock/server/**/*.ts",
    "eslint.config.*",
    "plugins/**/*"
  ],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "paths": {
      "#build/ui": ["./node_modules/.nuxt-ui/ui"]
    }
  }
}
